model Bill {
  id          Int      @id @default(autoincrement())
  userId      Int
  users       Users    @relation(fields: [userId], references: [id])
  groupId     Int
  groups      Groups?  @relation(fields: [groupId], references: [id])
  bill_name   String
  totalAmount Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  billSplits BillSplit[]
}

model BillSplit {
  id          Int        @id @default(autoincrement())
  billId      Int
  bills       Bill       @relation(fields: [billId], references: [id], onDelete: Cascade)
  userId      Int
  users       Users      @relation(fields: [userId], references: [id])
  splitAmount Int
  status      StatusType
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Budget {
  id        Int      @id @default(autoincrement())
  userId      Int
  users       Users      @relation(fields: [userId], references: [id])
  amount      Int
  type        BudgetType
  description String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
