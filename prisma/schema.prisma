model Bill {
  id          String   @id @default(uuid())
  userId      Int
  users       Users    @relation(fields: [userId], references: [id])
  groupId     String?
  groups      Groups?  @relation(fields: [groupId], references: [id])
  bill_name   String
  totalAmount Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  billSplits BillSplit[]
}

model BillSplit {
  id          String     @id @default(uuid())
  billId      String
  bills       Bill       @relation(fields: [billId], references: [id], onDelete: Cascade)
  userId      Int
  users       Users      @relation(fields: [userId], references: [id])
  splitAmount Int
  status      StatusType
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Budget {
  id          String     @id @default(uuid())
  userId      Int
  users       Users      @relation(fields: [userId], references: [id])
  amount      Int
  type        BudgetType
  description String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
