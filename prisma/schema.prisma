model Bill {
  id          String   @id @default(uuid())
  userId      String // Foreign key to Users
  users       Users    @relation(fields: [userId], references: [id])
  groupId     String? // Foreign key to Groups (optional, for group bills)
  groups      Groups?  @relation(fields: [groupId], references: [id])
  bill_name   String
  totalAmount Int // Total amount for the bill
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  billSplits BillSplit[] // Relation to BillSplit
}

model BillSplit {
  id          String   @id @default(uuid())
  billId      String // Foreign key to Bill
  bills       Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  userId      String // Foreign key to Users
  users       Users    @relation(fields: [userId], references: [id])
  splitAmount Int // Amount assigned to this user
  status      String // Example: "paid", "pending"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Budget {
  id          String     @id @default(uuid())
  userId      String // Foreign key to Users
  users       Users      @relation(fields: [userId], references: [id])
  amount      Int
  type        BudgetType // Enum field for short-term and long-term budget
  description String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
