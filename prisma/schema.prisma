
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BudgetType {
  SHORT_TERM
  LONG_TERM
}

model Users {
  id        String   @id @default(uuid())
  name      String
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Groups      Groups[]
  UsersGroups UsersGroups[]
  Category    Category[]
  Expenses    Expenses[]
  Saving      Saving[]
  Bill        Bill[]
  Budget      Budget[]
  BillSplit   BillSplit[]
}
model Groups {
  id         String   @id @default(uuid())
  group_name String   @unique
  userId     String
  created_by Users    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  UsersGroups UsersGroups[]
  Bill        Bill[]
}

model UsersGroups {
  id      String @id @default(uuid())
  userId  String // Foreign key to Users
  groupId String // Foreign key to Groups

  users     Users    @relation(fields: [userId], references: [id])
  groups    Groups   @relation(fields: [groupId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, groupId]) // Ensure no duplicate user-group combinations
}

model Category {
  id            String     @id @default(uuid())
  userId        String // Foreign key to Users
  users         Users      @relation(fields: [userId], references: [id])
  category_name String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  Expenses      Expenses[]
}

model Expenses {
  id          String   @id @default(uuid())
  userId      String // Foreign key to Users
  users       Users    @relation(fields: [userId], references: [id])
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  amount      Int
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Saving {
  id          String   @id @default(uuid())
  userId      String // Foreign key to Users
  users       Users    @relation(fields: [userId], references: [id])
  amount      Int
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

